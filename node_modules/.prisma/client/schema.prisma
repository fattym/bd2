generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int         @id @default(autoincrement())
  email      String      @unique
  name       String
  password   String?
  region     String?
  latitude   Float?
  longitude  Float?
  products   Product[]
  inventory  Inventory[]
  stock_logs StockLog[]

  @@map("users")
}

model Product {
  id         Int        @id @default(autoincrement())
  barcode    String
  name       String?
  user_id    Int
  user       User       @relation(fields: [user_id], references: [id])
  inventory  Inventory?
  stock_logs StockLog[]

  @@unique([barcode, user_id])
  @@map("products")
}

model Inventory {
  id               Int      @id @default(autoincrement())
  product_id       Int      @unique
  user_id          Int
  user             User     @relation(fields: [user_id], references: [id])
  current_quantity Int      @default(0)
  last_updated     DateTime @default(now())
  product          Product  @relation(fields: [product_id], references: [id])

  @@map("inventory")
}

model StockLog {
  id            Int      @id @default(autoincrement())
  product_id    Int
  user_id       Int
  user          User     @relation(fields: [user_id], references: [id])
  change_amount Int
  reason        String
  staff_id      String
  timestamp     DateTime @default(now())
  product       Product  @relation(fields: [product_id], references: [id])

  @@map("stock_logs")
}
